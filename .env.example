# =================================================================
# autolangchat Configuration Example
# =================================================================
# Copy this file to .env and modify the values as needed.
# All values shown here are the defaults used by the system.

# =================================================================
# REQUIRED: AWS Configuration
# =================================================================
# Set your AWS region where Bedrock is available
AWS_REGION=us-east-1

# AWS Credentials (optional if using IAM roles or AWS CLI profile)
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here

# =================================================================
# Model Configuration
# =================================================================
# Available Bedrock models:

# Claude Models (Anthropic)
# - us.anthropic.claude-sonnet-5 (Claude Sonnet 5 - LATEST, most advanced)
# - us.anthropic.claude-3-5-sonnet-20241022-v2:0 (Claude 3.5 Sonnet - with inference profile)
# - anthropic.claude-3-5-sonnet-20241022-v2:0 (Claude 3.5 Sonnet - recommended, most capable)
# - anthropic.claude-3-5-haiku-20241022-v1:0 (Claude 3.5 Haiku - faster, cheaper)
# - anthropic.claude-3-haiku-20240307-v1:0 (Claude 3 Haiku - legacy, cheapest)

# OpenAI GPT OSS Models
# - openai.gpt-oss-120b-1:0 (120B parameter open-source model - excellent performance)

# Meta Llama Models (Excellent for Tool Calling)
# - us.meta.llama3-2-90b-instruct-v1:0 (Llama 3.2 90B - NEWEST, excellent tool calling, cross-region profile)
# - meta.llama3-1-70b-instruct-v1:0 (Llama 3.1 70B - great for structured outputs)
# - meta.llama3-1-8b-instruct-v1:0 (Llama 3.1 8B - fast, good for simple tools)

# Cohere Command Models (Strong Multi-Step Reasoning)
# - cohere.command-r-plus-v1:0 (Command R+ - excellent for complex tool workflows)
# - cohere.command-r-v1:0 (Command R - good balance of speed and capability)

# Other Models
# - amazon.titan-text-express-v1 (Amazon Titan - basic text generation)
# - ai21.jamba-instruct-v1:0 (AI21 Jamba - hybrid architecture, long context)

# Default: Claude 5 Sonnet (latest and most advanced)
AUTOCHAT_MODEL_ID=us.anthropic.claude-sonnet-5

# Temperature controls randomness (0.0 = deterministic, 1.0 = very random)
AUTOCHAT_TEMPERATURE=0.7

# Maximum tokens in model response (affects cost and response length)
AUTOCHAT_MAX_TOKENS=4096

# Top-p sampling parameter (0.0-1.0)
# PARAMETER COMPATIBILITY:
# - Claude models: Use EITHER temperature OR top_p, not both (validation error if both)
# - OpenAI GPT models: Support BOTH temperature AND top_p simultaneously
# - Other models: Check model-specific documentation
AUTOCHAT_TOP_P=0.9

# =================================================================
# System Prompt
# =================================================================
# Define the AI assistant's behavior and capabilities
AUTOCHAT_SYSTEM_PROMPT="You are a helpful AI assistant for this API. Use the available tools to provide accurate information and help users accomplish their tasks."

# =================================================================
# API Endpoints
# =================================================================
# Customize the chat endpoints
AUTOCHAT_CHAT_ENDPOINT=/chat
AUTOCHAT_WEBSOCKET_ENDPOINT=/chat/ws
AUTOCHAT_UI_ENDPOINT=/chat/ui

# Enable/disable the built-in chat UI
AUTOCHAT_ENABLE_UI=true

# UI title and welcome message
# AUTOCHAT_UI_TITLE=AI Assistant
# AUTOCHAT_UI_WELCOME_MESSAGE=Welcome! I'm your AI assistant.

# =================================================================
# Preset Prompt Buttons
# =================================================================
# Path to a YAML file defining one-click prompt buttons shown in the chat UI.
# The file must have a top-level 'prompts' list; each entry needs 'label' and
# 'template' keys. Use {{JOB_ID}} in templates as a placeholder for a job UUID
# (the UI will auto-detect it from previous messages or prompt the user).
# Requires pyyaml: pip install pyyaml
# AUTOCHAT_PRESET_PROMPTS_FILE=./prompts.yaml

# =================================================================
# Tool Configuration
# =================================================================
# Path to OpenAPI spec file for framework-agnostic tool generation
# Use this when integrating with non-FastAPI frameworks (Express.js, Flask, etc.)
# AUTOCHAT_OPENAPI_SPEC_FILE=./openapi-spec.json

# Base URL for API calls (auto-detected if not specified)
# Set this when your API runs on a different port or host
# AUTOCHAT_API_BASE_URL=http://localhost:8080

# Which API paths the AI can access (comma-separated)
# Leave empty to allow all paths except excluded ones
AUTOCHAT_ALLOWED_PATHS=

# Which API paths to exclude from AI access (comma-separated)
AUTOCHAT_EXCLUDED_PATHS=/docs,/redoc,/openapi.json,/chat

# Maximum tool calls per single conversation turn.
# Unset (default) = unlimited. Set to a positive integer to cap per-turn calls.
# AUTOCHAT_MAX_TOOL_CALLS=20

# Timeout for API calls in seconds
AUTOCHAT_TIMEOUT=30

# =================================================================
# Session Management
# =================================================================
# Maximum concurrent WebSocket sessions
AUTOCHAT_MAX_SESSIONS=1000

# Session timeout in seconds (1 hour = 3600)
AUTOCHAT_SESSION_TIMEOUT=3600

# =================================================================
# Authentication & Security
# =================================================================
# Enable authentication for tool calls
# When enabled, users must provide credentials before making API calls
AUTOCHAT_ENABLE_TOOL_AUTH=true

# Supported authentication types (JSON array format)
# Options: bearer_token, basic_auth, api_key, oauth2_client_credentials, custom
AUTOCHAT_SUPPORTED_AUTH_TYPES=["bearer_token", "basic_auth", "api_key", "oauth2_client_credentials", "custom"]

# Require authentication before any tool calls can be made
# Set to true to make auth mandatory, false for optional
AUTOCHAT_REQUIRE_TOOL_AUTH=false

# Cache TTL for OAuth2 tokens in seconds (3600 = 1 hour)
# Tokens are automatically refreshed at 90% of this TTL
AUTOCHAT_AUTH_TOKEN_CACHE_TTL=3600

# Rate limiting (examples: "10/minute", "100/hour", "1000/day")
# AUTOCHAT_RATE_LIMIT=60/minute

# CORS origins (comma-separated, * for all)
AUTOCHAT_CORS_ORIGINS=*

# =================================================================
# Logging
# =================================================================
# Log levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
AUTOCHAT_LOG_LEVEL=INFO

# Log all API calls for debugging (can be verbose)
AUTOCHAT_LOG_API_CALLS=false

# Log errors
AUTOCHAT_LOG_ERRORS=true

# =================================================================
# Error Handling & Reliability
# =================================================================
# Maximum retries for failed requests
AUTOCHAT_MAX_RETRIES=3

# Delay between retries in seconds
AUTOCHAT_RETRY_DELAY=1.0

# Use exponential backoff for retries
AUTOCHAT_EXPONENTIAL_BACKOFF=true

# Continue working even if some features fail
AUTOCHAT_GRACEFUL_DEGRADATION=true

# Fallback model if primary model fails
# AUTOCHAT_FALLBACK_MODEL=anthropic.claude-3-5-haiku-20241022-v1:0

# =================================================================
# Chat Manager / Summarization Configuration
# =================================================================
# LLM client type: always "bedrock" via LangGraph ChatBedrockConverse
# (llm_client_type field removed — LangGraph handles routing)

# Enable AI-based summarization for oversized messages and conversation history.
# When enabled, uses LLM calls to intelligently condense content instead of
# plain text truncation. Increases LLM token usage.
# AUTOCHAT_ENABLE_AI_SUMMARIZATION=false

# For truncation thresholds and tuning, see the "Message Truncation" section below.
# See also docs/AI_SUMMARIZATION.md for presets and guidance.

# =================================================================
# Conversation Management
# =================================================================
# Maximum number of conversation messages to keep in history.
# Reduce this if you encounter "Input is too long" errors.
# IMPORTANT: For repeated large inputs, use very low values (5-10) to prevent
# "Failed to buffer the request body: length limit exceeded" errors.
# NOTE: GPT OSS models may encounter tokenization errors in conversations >10-12 exchanges.
# For finer-grained control, tune the Message Truncation settings below or
# enable AI summarization (AUTOCHAT_ENABLE_AI_SUMMARIZATION).
AUTOCHAT_MAX_CONVERSATION_MESSAGES=20

# Whether to preserve the system message during conversation trimming
AUTOCHAT_PRESERVE_SYSTEM_MESSAGE=true

# =================================================================
# Message Truncation (Unified System — replaces legacy Tool Result Truncation)
# =================================================================
# These settings apply to ALL message types, not just tool results.
# See docs/AI_SUMMARIZATION.md for presets and tuning guidance.

# Single-message truncation: Maximum individual message size before truncation
AUTOCHAT_SINGLE_MSG_LENGTH_THRESHOLD=500000

# Single-message truncation: Target size after truncation (~85% of threshold)
AUTOCHAT_SINGLE_MSG_TRUNCATION_TARGET=425000

# History per-message truncation: Threshold for messages during history reduction
AUTOCHAT_HISTORY_MSG_LENGTH_THRESHOLD=100000

# History-total truncation: Maximum combined history size before reduction
AUTOCHAT_HISTORY_TOTAL_LENGTH_THRESHOLD=650000

# History per-message truncation: Target size after truncation (~85% of threshold)
AUTOCHAT_HISTORY_MSG_TRUNCATION_TARGET=85000

# Maximum recursive truncation passes before giving up
AUTOCHAT_MAX_TRUNCATION_RECURSION=3

# NOTE: The following legacy env vars have been removed:
#   AUTOCHAT_TOOL_RESULT_NEW_RESPONSE_THRESHOLD → AUTOCHAT_SINGLE_MSG_LENGTH_THRESHOLD
#   AUTOCHAT_TOOL_RESULT_NEW_RESPONSE_TARGET    → AUTOCHAT_SINGLE_MSG_TRUNCATION_TARGET
#   AUTOCHAT_TOOL_RESULT_HISTORY_THRESHOLD      → AUTOCHAT_HISTORY_MSG_LENGTH_THRESHOLD
#   AUTOCHAT_TOOL_RESULT_HISTORY_TARGET         → AUTOCHAT_HISTORY_MSG_TRUNCATION_TARGET

# =================================================================
# Advanced Tool Handling
# =================================================================
# Maximum number of recursive tool call rounds
AUTOCHAT_MAX_TOOL_CALL_ROUNDS=5

# =================================================================
# Model-Specific Notes
# =================================================================
# GPT OSS Models: Have stricter limits and special considerations:
# - Context window: max_tokens automatically reduced to 1-10 tokens for large inputs
# - Request body size: Large chunked conversations can exceed HTTP body limits
# - Tokenization issues: May encounter "Unexpected token" errors in longer conversations
# - Repeated large inputs in same conversation create exponentially larger requests
# - Recommendations: smaller chunks (10000-20000), fewer messages (5-10), or start new conversations
# - System automatically applies ultra-aggressive fallback (truncates to ~2-3 messages)
# - For frequent large inputs or long conversations, Claude models handle interactions better
#
# Claude Models: Handle large conversations more gracefully and typically
# don't require max_tokens adjustments or aggressive conversation management.
#
# Meta Llama Models: Excellent for tool calling with strong structured output capabilities.
# - Llama 3.2 90B: Best overall performance for complex tool workflows
# - Llama 3.1 70B: Great balance of capability and speed for most tool calling tasks
# - Handle tool calling reliably with good parameter extraction
#
# Cohere Command Models: Specialized in multi-step reasoning and RAG workflows.
# - Command R+: Excellent for complex tool sequences and retrieval tasks
# - Command R: Good for standard tool calling with efficient performance

# =================================================================
# Environment-Specific Overrides
# =================================================================

# Development settings (faster/cheaper models for testing)
# AUTOCHAT_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
# AUTOCHAT_TEMPERATURE=0.3
# AUTOCHAT_LOG_API_CALLS=true
# AUTOCHAT_LOG_LEVEL=DEBUG

# Production settings (latest models with security)
# AUTOCHAT_MODEL_ID=us.anthropic.claude-sonnet-5
# AUTOCHAT_ENABLE_UI=false
# AUTOCHAT_RATE_LIMIT=30/minute
# AUTOCHAT_LOG_API_CALLS=false
# AUTOCHAT_MAX_SESSIONS=500

# Testing settings (deterministic responses)
# AUTOCHAT_MODEL_ID=openai.gpt-oss-120b-1:0
# AUTOCHAT_TEMPERATURE=0.0
# AUTOCHAT_MAX_TOOL_CALLS=5
# AUTOCHAT_TIMEOUT=10

# =================================================================
# Knowledge Base / RAG Storage Backend
# =================================================================
# Storage backend for the KB vector database.
# Options: "sqlite" (default, file-based) or "pgvector" (PostgreSQL).
# AUTOCHAT_KB_STORAGE_TYPE=sqlite

# --- SQLite (default) ---
# Path to the SQLite database file (used when AUTOCHAT_KB_STORAGE_TYPE=sqlite).
# KB_DATABASE_PATH=data/knowledge_base.db

# --- PostgreSQL + pgvector ---
# Required when AUTOCHAT_KB_STORAGE_TYPE=pgvector.
# Install optional deps: pip install autolangchat[postgres]
# AUTOCHAT_KB_POSTGRES_URL=postgresql://kb_user:kb_password@localhost:5432/knowledge_base
# AUTOCHAT_KB_POSTGRES_POOL_SIZE=5

# Embedding vector dimensions (must match your embedding model output).
# Default: 1536 (Amazon Titan Embed Text v1 / OpenAI). Common: 1024, 384.
# AUTOCHAT_KB_EMBEDDING_DIMENSIONS=1536

# --- Docker Compose quick-start ---
# Default docker-compose.yml starts PostgreSQL + pgvector:
#   docker compose up
#
# For SQLite-only (no PostgreSQL container):
#   docker compose -f docker-compose.yml -f docker-compose.sqlite.yml up
