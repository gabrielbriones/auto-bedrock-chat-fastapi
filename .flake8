[flake8]
max-line-length = 120
ignore = E203,W503,E501,B036
exclude =
    .git,
    __pycache__,
    .venv,
    .env,
    build,
    dist,
    .tox,
    .eggs,
    *.egg,
    .pytest_cache,
    .mypy_cache,
    htmlcov
per-file-ignores =
    __init__.py:F401
    examples/fastAPI/app_auth.py:B008
    # Test modules intentionally use import-heavy fixtures and explicit
    # literals to keep assertions readable.
    tests/*.py:F401,F841,F541,F601
    # FastAPI's idiomatic dependency-injection pattern uses ``Depends(...)``
    # and ``Query(...)`` as default values; B008 misfires here.
    autolangchat/admin/admin_feedback_routes.py:B008
    autolangchat/admin/admin_kb_routes.py:B008
    autolangchat/admin/admin_token_routes.py:B008
    autolangchat/conversation_routes.py:B008
    tests/test_admin_auth.py:B008
    # Protocol method body uses ``...`` on the same line (PEP 544 idiom).
    autolangchat/admin/admin_auth.py:E704
